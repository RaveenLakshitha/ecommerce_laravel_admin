{
    "version": "7.3",
    "data_api_version": "3.0",
    "routing_model": {
        "TYPE": ["DOCTOR_SELECT", "SPECIALIZATION"],
        "SPECIALIZATION": ["VISIT_TYPE"],
        "DOCTOR_SELECT": ["VISIT_TYPE"],
        "VISIT_TYPE": ["PATIENT_NEW", "MRN_ONLY"],
        "PATIENT_NEW": ["PREFERRED_TIME"],
        "MRN_ONLY": ["PREFERRED_TIME"],
        "PREFERRED_TIME": ["REASON"],
        "REASON": ["SUMMARY"],
        "SUMMARY": []
    },
    "screens": [
        {
            "id": "TYPE",
            "title": "...",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "TextSubheading",
                        "text": "Hi! Welcome to Medical Centre🖐️"
                    },
                    {
                        "type": "TextBody",
                        "text": "Request to schedule an appointment with our expert consultants."
                    },     
                    {
                        "type": "Form",
                        "name": "type_form",
                        "children": [
                            {
                                "type": "RadioButtonsGroup",
                                "label": "I want to see",
                                "name": "appointment_type",
                                "data-source": [
                                    { "id": "specific", "title": "Specific doctor" },
                                    { "id": "any", "title": "Specilized doctor from" }
                                ],
                                "required": true
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "select_appointment_type",
                                        "appointment_type": "${form.appointment_type}",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "SPECIALIZATION",
            "title": "Specialization",
            "data": {
                "appointment_type": { "type": "string", "__example__": "any" },
                "specializations": {
                    "type": "array",
                    "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
                    "__example__": []
                },
                "specialization": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "TextSubheading",
                        "text": "Choose a Specialization"
                    },
                    {
                        "type": "TextBody",
                        "text": "Please select the department you are looking for👇"
                    },
                    {
                        "type": "Form",
                        "name": "specialization_form",
                        "children": [
                            {
                                "type": "Dropdown",
                                "label": "Specialization",
                                "name": "specialization",
                                "data-source": "${data.specializations}",
                                "required": true,
                                "on-select-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "specialization_selected",
                                        "appointment_type": "${data.appointment_type}",
                                        "specialization": "${form.specialization}",
                                        "error_message": ""
                                    }
                                }
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "navigate",
                                    "next": { "type": "screen", "name": "VISIT_TYPE" },
                                    "payload": {
                                        "appointment_type": "${data.appointment_type}",
                                        "specialization": "${data.specialization}",
                                        "doctor": "${data.doctor}",
                                        "visit_type": "",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "DOCTOR_SELECT",
            "title": "Select Doctor",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "doctors": {
                    "type": "array",
                    "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
                    "__example__": []
                },
                "doctor": { "type": "string", "__example__": "" },
                "specialization": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "doctor_form",
                        "children": [
                            {
                                "type": "TextSubheading",
                                "text": "Here are the doctors"
                            },
                            {
                                "type": "TextBody",
                                "text": "Please select the doctor you would like to meet👇"
                            },
                            {
                                "type": "Dropdown",
                                "label": "Doctor",
                                "name": "doctor",
                                "data-source": "${data.doctors}",
                                "required": true,
                                "on-select-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "doctor_selected",
                                        "appointment_type": "${data.appointment_type}",
                                        "doctor": "${form.doctor}",
                                        "error_message": ""
                                    }
                                }
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "navigate",
                                    "next": { "type": "screen", "name": "VISIT_TYPE" },
                                    "payload": {
                                        "appointment_type": "${data.appointment_type}",
                                        "doctor": "${data.doctor}",
                                        "specialization": "${data.specialization}",
                                        "visit_type": "",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "VISIT_TYPE",
            "title": "Visit Type",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "visit_type": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "specialization": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "visit_type_form",
                        "children": [
                            {
                                "type": "RadioButtonsGroup",
                                "label": "Is this your first visit or a follow-up?",
                                "name": "visit_type",
                                "data-source": [
                                    { "id": "first", "title": "First Visit" },
                                    { "id": "followup", "title": "Follow-up Visit" }
                                ],
                                "required": true
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "select_visit_type",
                                        "appointment_type": "${data.appointment_type}",
                                        "visit_type": "${form.visit_type}",
                                        "doctor": "${data.doctor}",
                                        "specialization": "${data.specialization}",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "PATIENT_NEW",
            "title": "New Patient Details",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "visit_type": { "type": "string", "__example__": "first" },
                "first_name": { "type": "string", "__example__": "" },
                "last_name": { "type": "string", "__example__": "" },
                "phone": { "type": "string", "__example__": "" },
                "email": { "type": "string", "__example__": "" },
                "dob": { "type": "string", "__example__": "" },
                "gender": { "type": "string", "__example__": "" },
                "address": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "specialization": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "patient_form",
                        "children": [
                            {
                                "type": "TextBody",
                                "text": "Enter the Patient details"
                            }, 
                            {
                                "type": "TextInput",
                                "label": "First Name",
                                "name": "first_name",
                                "required": true
                            },
                            {
                                "type": "TextInput",
                                "label": "Last Name",
                                "name": "last_name",
                                "required": true
                            },
                            {
                                "type": "TextInput",
                                "label": "Phone",
                                "name": "phone",
                                "input-type": "phone",
                                "required": true
                            },
                            {
                                "type": "TextInput",
                                "label": "Email",
                                "name": "email",
                                "input-type": "email",
                                "required": false
                            },
                            {
                                "type": "TextInput",
                                "label": "Date of Birth",
                                "name": "dob",
                                "input-type": "text",
                                "required": true,
                                "helper-text": "YYYY-MM-DD (example: 1990-05-15)"
                            },
                            {
                                "type": "Dropdown",
                                "label": "Gender",
                                "name": "gender",
                                "data-source": [
                                    { "id": "male", "title": "Male" },
                                    { "id": "female", "title": "Female" },
                                    { "id": "other", "title": "Other" }
                                ],
                                "required": true
                            },
                            {
                                "type": "TextArea",
                                "label": "Address",
                                "name": "address",
                                "required": false
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "create_patient",
                                        "first_name": "${form.first_name}",
                                        "last_name": "${form.last_name}",
                                        "phone": "${form.phone}",
                                        "email": "${form.email}",
                                        "dob": "${form.dob}",
                                        "gender": "${form.gender}",
                                        "address": "${form.address}",
                                        "appointment_type": "${data.appointment_type}",
                                        "visit_type": "${data.visit_type}",
                                        "doctor": "${data.doctor}",
                                        "specialization": "${data.specialization}",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "MRN_ONLY",
            "title": "Existing Patient (MRN)",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "visit_type": { "type": "string", "__example__": "followup" },
                "mrn": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "specialization": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "mrn_form",
                        "children": [
                            {
                                "type": "TextBody",
                                "text": "Enter your 6 digit MR Number below 👇"
                            }, 
                            {
                                "type": "TextInput",
                                "label": "MR Number",
                                "name": "mrn",
                                "required": true
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "lookup_patient_by_mrn",
                                        "mrn": "${form.mrn}",
                                        "appointment_type": "${data.appointment_type}",
                                        "visit_type": "${data.visit_type}",
                                        "doctor": "${data.doctor}",
                                        "specialization": "${data.specialization}",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "PREFERRED_TIME",
            "title": "Preferred Time",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "patient": { "type": "string", "__example__": "" },
                "visit_type": { "type": "string", "__example__": "first" },
                "preferred_time": { "type": "string", "__example__": "next" },
                "specialization": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "preferred_time_form",
                        "children": [
                            {
                                "type": "TextBody",
                                "text": "When do you prefer to meet the doctor?"
                            }, 
                            {
                                "type": "Dropdown",
                                "label": "Preferred Time",
                                "name": "preferred_time",
                                "data-source": [
                                    { "id": "next", "title": "Next available slot" },
                                    { "id": "7days", "title": "Within next 7 days" },
                                    { "id": "15days", "title": "Within next 15 days" }
                                ],
                                "required": true
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "navigate",
                                    "next": { "type": "screen", "name": "REASON" },
                                    "payload": {
                                        "appointment_type": "${data.appointment_type}",
                                        "patient": "${data.patient}",
                                        "visit_type": "${data.visit_type}",
                                        "preferred_time": "${form.preferred_time}",
                                        "specialization": "${data.specialization}",
                                        "doctor": "${data.doctor}",
                                        "reason": "",
                                        "details_text": "",
                                        "notes": "",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "REASON",
            "title": "Reason for Visit",
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "patient": { "type": "string", "__example__": "" },
                "visit_type": { "type": "string", "__example__": "first" },
                "preferred_time": { "type": "string", "__example__": "next" },
                "reason": { "type": "string", "__example__": "" },
                "specialization": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "notes": { "type": "string", "__example__": "" },
                "details_text": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "reason_form",
                        "children": [
                            {
                                "type": "TextArea",
                                "label": "Reason for visit",
                                "name": "reason",
                                "required": true,
                                "helper-text": "Please describe your main concern"
                            },
                            {
                                "type": "TextArea",
                                "label": "Additional notes",
                                "name": "notes",
                                "required": false
                            },
                            {
                                "type": "Footer",
                                "label": "Continue",
                                "on-click-action": {
                                    "name": "navigate",
                                    "next": { "type": "screen", "name": "SUMMARY" },
                                    "payload": {
                                        "appointment_type": "${data.appointment_type}",
                                        "patient": "${data.patient}",
                                        "visit_type": "${data.visit_type}",
                                        "preferred_time": "${data.preferred_time}",
                                        "reason": "${form.reason}",
                                        "specialization": "${data.specialization}",
                                        "doctor": "${data.doctor}",
                                        "notes": "${form.notes}",
                                        "details_text": "${data.details_text}",
                                        "error_message": ""
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "SUMMARY",
            "title": "Summary & Confirmation",
            "terminal": true,
            "data": {
                "appointment_type": { "type": "string", "__example__": "specific" },
                "patient": { "type": "string", "__example__": "" },
                "visit_type": { "type": "string", "__example__": "first" },
                "preferred_time": { "type": "string", "__example__": "next" },
                "reason": { "type": "string", "__example__": "" },
                "notes": { "type": "string", "__example__": "" },
                "specialization": { "type": "string", "__example__": "" },
                "doctor": { "type": "string", "__example__": "" },
                "details_text": { "type": "string", "__example__": "" },
                "error_message": { "type": "string", "__example__": "" }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Form",
                        "name": "summary_form",
                        "children": [
                            {
                                "type": "TextHeading",
                                "text": "Appointment Summary"
                            },
                            {
                                "type": "TextBody",
                                "text": "${data.appointment_type}"
                            },
                            {
                                "type": "TextHeading",
                                "text": "Details"
                            },
                            {
                                "type": "TextBody",
                                "text": "${data.details_text}"
                            },
                            {
                                "type": "Footer",
                                "label": "Confirm Appointment",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "appointment_type": "${data.appointment_type}",
                                        "patient": "${data.patient}",
                                        "visit_type": "${data.visit_type}",
                                        "preferred_time": "${data.preferred_time}",
                                        "reason": "${data.reason}",
                                        "specialization": "${data.specialization}",
                                        "doctor": "${data.doctor}",
                                        "notes": "${data.notes}",
                                        "error_message": "",
                                        "complete": true
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        }
    ]
}